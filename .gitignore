# ===================================
# GastoTrack - Git Ignore File
# ===================================

# ===================================
# Backend (Laravel)
# ===================================
backend/app/vendor/
backend/app/node_modules/
backend/app/.env
backend/app/.env.backup
backend/app/.phpunit.result.cache
backend/app/Homestead.json
backend/app/Homestead.yaml
backend/app/npm-debug.log
backend/app/yarn-error.log
backend/app/.idea
backend/app/.vscode
backend/app/storage/*.key
backend/app/storage/logs/*.log
backend/app/storage/framework/cache/*
backend/app/storage/framework/sessions/*
backend/app/storage/framework/views/*
backend/app/bootstrap/cache/*
backend/app/public/hot
backend/app/public/storage
backend/app/database/database.sqlite

# ===================================
# Mobile (React Native / Expo)
# ===================================
mobile/node_modules/
mobile/npm-debug.log
mobile/yarn-error.log
mobile/.expo/
mobile/.expo-shared/
mobile/dist/
mobile/web-build/

# Android
mobile/android/app/build/
mobile/android/build/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/captures/
mobile/android/app/release/
mobile/android/.cxx/
mobile/android/*.apk
mobile/android/*.aab
mobile/android/*.aar

# iOS (if you add iOS support later)
mobile/ios/Pods/
mobile/ios/build/
mobile/ios/*.xcworkspace
mobile/ios/*.xcodeproj

# ===================================
# Environment & Config
# ===================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ===================================
# IDE & Editor
# ===================================
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# ===================================
# OS Files
# ===================================
Thumbs.db
Desktop.ini
.DS_Store
.AppleDouble
.LSOverride

# ===================================
# Build Files
# ===================================
*.apk
*.aab
*.ipa
build/
dist/

# ===================================
# Logs
# ===================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ===================================
# Temporary Files
# ===================================
*.tmp
*.temp
.cache/
tmp/
temp/

# ===================================
# Keep These Files (Don't Ignore)
# ===================================
!backend/app/.env.example
!backend/app/storage/.gitkeep
!backend/app/storage/app/.gitkeep
!backend/app/storage/framework/.gitkeep
!backend/app/storage/logs/.gitkeep
